{
    "name": "puchitto",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./networking": {
            "types": "./dist/networking.d.ts",
            "import": "./dist/networking.js"
        },
        "./scripting": {
            "types": "./dist/scripting.d.ts",
            "import": "./dist/scripting.js"
        },
        "./components": {
            "types": "./dist/components.d.ts",
            "import": "./dist/components.js"
        },
        "./tweening": {
            "types": "./dist/tweening.d.ts",
            "import": "./dist/tweening.js"
        },
        "./level": {
            "types": "./dist/level.d.ts",
            "import": "./dist/level.js"
        },
        "./objects": {
            "types": "./dist/objects.d.ts",
            "import": "./dist/objects.js"
        },
        "./data": {
            "types": "./dist/data.d.ts",
            "import": "./dist/data.js"
        },
        "./alf": {
            "types": "./dist/alf.d.ts",
            "import": "./dist/alf.js"
        }
    },
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/three": "^0.183.1",
        "three": "^0.183.2",
        "tsup": "^8.5.1"
    },
    "peerDependencies": {
        "@mary/events": "npm:@jsr/mary__events@^0.2.0",
        "three": ">=0.183.2"
    }
}
